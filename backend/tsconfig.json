{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "rootDir": "..",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "../shared/types.ts"],
  "exclude": ["node_modules", "dist"]
}
